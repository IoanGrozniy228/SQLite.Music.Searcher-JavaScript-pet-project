<!DOCTYPE html>
<html>
<head>
    <title>Music Searcher</title>
    <link rel="icon" type="image/x-icon" href="/img/logo.ico">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        
        <div class="logo">
            <img src="/img/logo.png" alt="Logo">   
        </div>
        <h1>MUSIC SEARCHER</h1>
        
        <div class="search-box">
            <select id="searchType">
                <option value="author">Artist</option>
                <option value="album">Album</option>
                <option value="song">Song</option>
            </select>
            <input type="text" id="searchInput" placeholder="Enter artist, album or song name...">
            <button onclick="search()">Search</button>
        </div>
        <div id="artistPhoto" class="artist-photo"></div>
        <div id="albumCover" class="album-cover"></div>
        <div id="results"></div>
    </div>
    <button class="export-btn" onclick="exportToExcel()">📊 Export to Excel</button>
    <script src="/js/script.js"></script>
</body>
</html>